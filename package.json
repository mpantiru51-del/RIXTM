{
  "name": "rixtm",
  "version": "1.0.0",
  "description": "RIXTM cryptocurrency",
  "main": "index.js",
  "scripts": {
    "rehearsal:deploy": "hardhat --network sepolia --build-profile production ignition deploy --deployment-id rixtm-mainnet-candidate-sepolia --verify ignition/modules/RIXTMMainnet.ts",
    "rehearsal:preflight": "hardhat --network sepolia run scripts/rehearsal-preflight.ts",
    "rehearsal:propose-owner": "hardhat --network sepolia run scripts/propose-mainnet-ownership.ts",
    "rehearsal:validate": "hardhat --network sepolia run scripts/validate-mainnet-candidate.ts",
    "test": "hardhat test",
    "start": "node index.js"
  },
  "author": "Marian Pantiru",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "hardhat": "^3.9.0"
  },
  "type": "module"
}

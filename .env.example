# Copy this file to .env and replace every placeholder locally.
# Never commit the resulting .env file or share its contents.
SEPOLIA_RPC_URL=replace_with_sepolia_rpc_url
SEPOLIA_PRIVATE_KEY=replace_with_dedicated_test_wallet_private_key
ETHERSCAN_API_KEY=replace_with_etherscan_api_key

# Fill these only after the candidate and multisig exist on Sepolia.
RIXTM_CANDIDATE_ADDRESS=
RIXTM_MULTISIG_ADDRESS=

# Leave empty except while proposing the two-step ownership transfer.
# The required value is TRANSFER_TO_<checksummed_multisig_address>.
RIXTM_CONFIRM_OWNERSHIP_TRANSFER=
